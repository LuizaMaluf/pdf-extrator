# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pdf_extractor

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Pipeline
CONFIDENCE_THRESHOLD=0.85
MAX_FEW_SHOT_EXAMPLES=5
MIN_FEW_SHOT_SCORE=0.6

# Storage
PDF_UPLOAD_DIR=/app/uploads
